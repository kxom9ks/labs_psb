## First rule - delete all
-D

## Increase the buffers to survive stress events.
## Make this bigger for busy systems
-b 8192

## This determine how long to wait in burst of events
--backlog_wait_time 60000

## Set failure mode to syslog
-f 1

-a always,exit -F arch=b64 -S chmod,fchmod,fchmodat -k CHMOD_COMMAND
-a always,exit -F arch=b32 -S chmod,fchmod,fchmodat -k CHMOD_COMMAND

-a always,exit -F arch=b64 -S chown,fchown,fchownat,lchown -k CHOWN_COMMAND
-a always,exit -F arch=b32 -S chown,fchown,fchownat,lchown -k CHOWN_COMMAND

-w /etc/ssh/sshd_config -p wa -k SSH_CONFIG

-a always,exit -F arch=b64 -C uid!=euid -S execve -F euid=0 -k SUDO_EXECUTE
-a always,exit -F arch=b32 -C uid!=euid -S execve -F euid=0 -k SUDO_EXECUTE

